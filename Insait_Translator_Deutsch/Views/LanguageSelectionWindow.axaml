<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="300"
        x:Class="Insait_Translator_Deutsch.Views.LanguageSelectionWindow"
        Title="Language Selection"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly"
        Width="500"
        Height="300"
        CanResize="False"
        UseLayoutRounding="True"
        FontFamily="Segoe UI, Arial, Tahoma">

    <Window.Resources>
        <Color x:Key="AppBgColor">#FFF5E6D3</Color>
        <Color x:Key="AppSurfaceColor">#FFFDF7EF</Color>
        <Color x:Key="AppBorderColor">#FFE8D5B7</Color>
        <Color x:Key="AppTextColor">#FF404040</Color>
        <Color x:Key="AccentOrangeColor">#FFFF8C00</Color>
        <Color x:Key="AccentPurpleColor">#7D2AE8</Color>

        <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource AppBgColor}" />
        <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource AppBorderColor}" />
        <SolidColorBrush x:Key="AppTextBrush" Color="{StaticResource AppTextColor}" />
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrangeColor}" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurpleColor}" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.dialog-button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentPurpleBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentPurpleBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.dialog-button:pointerover">
            <Setter Property="Background" Value="#FFFFA000"/>
        </Style>
        <Style Selector="Button.dialog-button.secondary">
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}"/>
        </Style>
        <Style Selector="Button.dialog-button.secondary:pointerover">
            <Setter Property="Background" Value="#FFFFFFFF"/>
        </Style>
    </Window.Styles>

    <Window.Background>
        <SolidColorBrush Color="{StaticResource AppBgColor}"/>
    </Window.Background>

    <Border Background="{StaticResource AppSurfaceBrush}" CornerRadius="8" Margin="12" Padding="20">
        <Grid RowDefinitions="Auto,Auto,*,Auto">
            <!-- Title -->
            <TextBlock Grid.Row="0" Name="TitleText" Text="Select Language" 
                       FontSize="18" FontWeight="Bold" 
                       Foreground="{StaticResource AccentPurpleBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            
            <!-- Description -->
            <TextBlock Grid.Row="1" Name="DescriptionText" Text="Select interface language:" 
                       FontSize="13" 
                       Foreground="{StaticResource AppTextBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
            
            <!-- Language ComboBox -->
            <ComboBox Grid.Row="2" Name="LanguageComboBox" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Top"
                      FontSize="14"
                      Height="40"
                      Padding="12,0"/>
            
            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,20,0,0">
                <Button Classes="dialog-button" Name="ApplyButton" Content="Apply" Click="ApplyButton_Click"/>
                <Button Classes="dialog-button secondary" Name="CancelButton" Content="Cancel" Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

