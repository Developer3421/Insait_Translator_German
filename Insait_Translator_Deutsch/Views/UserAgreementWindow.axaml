<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:chrome="using:Insait_Translator_Deutsch.Views.Chrome"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="550"
        x:Class="Insait_Translator_Deutsch.Views.UserAgreementWindow"
        Title="Угода користувача"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        Width="600"
        Height="550"
        CanResize="False"
        UseLayoutRounding="True"
        FontFamily="Segoe UI, Arial, Tahoma">

    <!-- LOCAL RESOURCES -->
    <Window.Resources>
        <!-- German B1 palette -->
        <Color x:Key="AppBgColor">#FFF5E6D3</Color>
        <Color x:Key="AppSurfaceColor">#FFFDF7EF</Color>
        <Color x:Key="AppBorderColor">#FFE8D5B7</Color>
        <Color x:Key="AppTextColor">#FF404040</Color>
        <Color x:Key="AppTextMutedColor">#FF606060</Color>

        <Color x:Key="AccentOrangeColor">#FFFF8C00</Color>
        <Color x:Key="AccentPurpleColor">#7D2AE8</Color>

        <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource AppBgColor}" />
        <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource AppBorderColor}" />
        <SolidColorBrush x:Key="AppTextBrush" Color="{StaticResource AppTextColor}" />
        <SolidColorBrush x:Key="AppTextMutedBrush" Color="{StaticResource AppTextMutedColor}" />

        <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrangeColor}" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurpleColor}" />

        <!-- Gray Gradient for Title Bar -->
        <LinearGradientBrush x:Key="GrayGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFE0E0E0" Offset="0"/>
            <GradientStop Color="#FFD0D0D0" Offset="0.3"/>
            <GradientStop Color="#FFC5C5C5" Offset="0.7"/>
            <GradientStop Color="#FFC0C0C0" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Window.Styles>
        <!-- Close Button -->
        <Style Selector="Button.close-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#303030"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.close-button:pointerover">
            <Setter Property="Background" Value="#40FF5C5C"/>
        </Style>

        <!-- OK Button -->
        <Style Selector="Button.ok-button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentPurpleBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentPurpleBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="32,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.ok-button:pointerover">
            <Setter Property="Background" Value="#FFFFA000"/>
        </Style>
        <Style Selector="Button.ok-button:pressed">
            <Setter Property="Background" Value="#FFFF9500"/>
        </Style>
    </Window.Styles>

    <Window.Background>
        <SolidColorBrush Color="{StaticResource AppBgColor}"/>
    </Window.Background>

    <Border BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="8">
        <Grid RowDefinitions="42,*">

            <chrome:CustomTitleBar Grid.Row="0">
                <chrome:CustomTitleBar.LeftContent>
                    <TextBlock Name="TitleBarText" Text="📜 Угода користувача" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </chrome:CustomTitleBar.LeftContent>
            </chrome:CustomTitleBar>

            <!-- Content -->
            <Border Grid.Row="1" Background="{StaticResource AppSurfaceBrush}" Padding="24">
                <Grid RowDefinitions="Auto,*,Auto">
                    
                    <!-- Header -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Name="HeaderText" Text="📜 Угода користувача" 
                                   FontSize="22" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentPurpleBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Name="SubheaderText" Text="Умови використання додатку" 
                                   FontSize="13" Foreground="{StaticResource AppTextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Agreement Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                        <Border Background="#20000000" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="16">
                                <!-- Section 1: Data Privacy -->
                                <StackPanel>
                                    <TextBlock Name="Section1TitleText" Text="🔒 Конфіденційність даних"
                                               FontWeight="Bold" FontSize="14"
                                               Foreground="{StaticResource AccentPurpleBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Name="Section1Text" 
                                               Text="Цей додаток не передає жодних даних на наші сервери. Вся інформація обробляється локально на вашому пристрої."
                                               FontSize="13" TextWrapping="Wrap" LineHeight="22"
                                               Foreground="{StaticResource AppTextBrush}"/>
                                </StackPanel>
                                
                                <!-- Section 2: Local Storage -->
                                <StackPanel>
                                    <TextBlock Name="Section2TitleText" Text="💾 Локальне зберігання"
                                               FontWeight="Bold" FontSize="14"
                                               Foreground="{StaticResource AccentPurpleBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Name="Section2Text" 
                                               Text="Читання та зберігання німецького перекладу або тексту відбувається виключно локально на вашому пристрої. Ваші дані залишаються під вашим контролем."
                                               FontSize="13" TextWrapping="Wrap" LineHeight="22"
                                               Foreground="{StaticResource AppTextBrush}"/>
                                </StackPanel>
                                
                                <!-- Section 3: Translation Providers -->
                                <StackPanel>
                                    <TextBlock Name="Section3TitleText" Text="🌐 Провайдери перекладу"
                                               FontWeight="Bold" FontSize="14"
                                               Foreground="{StaticResource AccentPurpleBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Name="Section3Text" 
                                               Text="Для здійснення перекладу додаток використовує сторонні сервіси (MyMemory, Gtranslate, Google Gemini API). Кожен із цих провайдерів має власну угоду користувача та політику конфіденційності. Рекомендуємо ознайомитися з їхніми умовами на офіційних сайтах."
                                               FontSize="13" TextWrapping="Wrap" LineHeight="22"
                                               Foreground="{StaticResource AppTextBrush}"/>
                                </StackPanel>
                                
                                <!-- Section 4: Responsibility -->
                                <StackPanel>
                                    <TextBlock Name="Section4TitleText" Text="⚠️ Відповідальність"
                                               FontWeight="Bold" FontSize="14"
                                               Foreground="{StaticResource AccentPurpleBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Name="Section4Text" 
                                               Text="Текст, який ви вводите для перекладу, надсилається безпосередньо провайдерам перекладу. Ми не несемо відповідальності за обробку даних цими сервісами. Не вводьте конфіденційну або особисту інформацію."
                                               FontSize="13" TextWrapping="Wrap" LineHeight="22"
                                               Foreground="{StaticResource AppTextBrush}"/>
                                </StackPanel>
                                
                                <!-- Section 5: Agreement -->
                                <StackPanel>
                                    <TextBlock Name="Section5TitleText" Text="✅ Згода"
                                               FontWeight="Bold" FontSize="14"
                                               Foreground="{StaticResource AccentPurpleBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Name="Section5Text" 
                                               Text="Використовуючи цей додаток, ви погоджуєтесь з цими умовами та умовами провайдерів перекладу."
                                               FontSize="13" TextWrapping="Wrap" LineHeight="22"
                                               Foreground="{StaticResource AppTextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <!-- Accept Button -->
                    <Button Grid.Row="2" Classes="ok-button" Name="AcceptButton" 
                            HorizontalAlignment="Center" Margin="0,16,0,0" Click="OkButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="✓" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Name="AcceptButtonText" Text="Зрозуміло" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

